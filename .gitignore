# Datos de entorno local
.env
*.log

# Archivos de sistema
.DS_Store
Thumbs.db

# Media extraction temporales (workspace local; no publicar cache cruda en GitHub)
tmp/media/*
!tmp/media/.gitkeep

# Media cache — reuso local entre sesiones; versionar .gitkeep y transcripciones .txt referenciadas desde lore
tmp/media-cache/*
!tmp/media-cache/.gitkeep
!tmp/media-cache/*.txt
